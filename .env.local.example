# Copy this file to .env.local and fill in the values.
# .env.local is gitignored. Never commit real values.
#
# Values are pulled from: Supabase dashboard → Project Settings → API Keys.
# Vercel also stores these (see `vercel env ls`).

# The Supabase project URL (https://<ref>.supabase.co). Browser-readable.
NEXT_PUBLIC_SUPABASE_URL=

# The "publishable" Supabase API key (prefix: sb_publishable_...). Replaces
# the legacy anon key under the new key format. Browser-readable; safe to
# expose. RLS still gates access via the authenticated/anon Postgres role.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# The "secret" Supabase API key (prefix: sb_secret_...). Replaces the legacy
# service_role key. Server-only — never prefix with NEXT_PUBLIC_, never ship
# to the browser, never log. Bypasses RLS.
SUPABASE_SECRET_KEY=

# Anthropic Console API key (prefix: sk-ant-api03-...). Server-only.
# Used by the drift re-rail and focus-pick AI calls. Rotate if leaked.
ANTHROPIC_API_KEY=
